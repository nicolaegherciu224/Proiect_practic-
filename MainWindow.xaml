<Window x:Class="EngineeringManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Engineering Management"
        Height="720"
        Width="1180"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Meniul lateral — lățime minimă fixă, se adaptează la redimensionare -->
            <ColumnDefinition Width="240" MinWidth="200" MaxWidth="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ========== BARA LATERALĂ (SIDEBAR) ========== -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!-- Logo / titlu aplicație -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
                    <TextBlock Text="Engineering"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextOnSidebarBrush}" />
                    <TextBlock Text="Management"
                               FontSize="14"
                               Foreground="#A8C4E8"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Butoane navigare — vizibilitatea se setează din cod după rol -->
                <StackPanel x:Name="MeniuNavigarePanel" Margin="0,8,0,0">
                    <Button x:Name="BtnAcasa"
                            Content="🏠  Acasă"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigare_Click"
                            Tag="Active" />
                    <Button x:Name="BtnSolicitari"
                            Content="📋  Solicitări"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigare_Click" />
                    <Button x:Name="BtnIngineri"
                            Content="👷  Ingineri"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigare_Click" />
                    <Button x:Name="BtnEchipamente"
                            Content="🔧  Echipamente"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigare_Click" />
                    <Button x:Name="BtnStatistici"
                            Content="📊  Statistici"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigare_Click" />
                    <Button x:Name="BtnConturi"
                            Content="👤  Conturi"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigare_Click" />
                </StackPanel>

                <!-- Informații utilizator în partea de jos a sidebar-ului -->
                <Border DockPanel.Dock="Bottom"
                        Margin="12"
                        Padding="12"
                        Background="{DynamicResource SidebarHoverBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock x:Name="SidebarUserText"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnSidebarBrush}" />
                        <TextBlock x:Name="SidebarRolText"
                                   FontSize="12"
                                   Foreground="#A8C4E8"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ========== ZONA PRINCIPALĂ (dreapta) ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Bara de sus: titlu pagină + comutare temă + deconectare -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TopBarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitluPaginaText"
                               Text="Acasă"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnComutaTema"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="ComutaTema_Click" />
                        <Button Content="Deconectare"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="Deconectare_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Zona de conținut — Frame obligatoriu pentru Page în WPF -->
            <Frame x:Name="ZonaContinut"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   JournalOwnership="OwnsJournal" />
        </Grid>
    </Grid>
</Window>
