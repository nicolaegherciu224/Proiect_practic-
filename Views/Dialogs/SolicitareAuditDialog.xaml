<Window x:Class="EngineeringManagementApp.Views.Dialogs.SolicitareAuditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Istoric status"
        Height="420"
        Width="720"
        MinHeight="320"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitluText" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Istoric schimbări de status / mentenanță"
                       Style="{StaticResource PageSubtitleStyle}"
                       Margin="0,6,0,0" />
        </StackPanel>

        <DataGrid x:Name="GridIstoric"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  AlternatingRowBackground="{DynamicResource PrimaryLightBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding DataSchimbare, StringFormat=dd.MM.yyyy HH:mm}" Width="140" />
                <DataGridTextColumn Header="Status vechi" Binding="{Binding StatusVechi}" Width="110" />
                <DataGridTextColumn Header="Status nou" Binding="{Binding StatusNou}" Width="110" />
                <DataGridTextColumn Header="Utilizator" Binding="{Binding Utilizator}" Width="120" />
                <DataGridTextColumn Header="Observații" Binding="{Binding Observatii}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
                Content="Închide"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Click="Inchide_Click" />
    </Grid>
</Window>
