<Page x:Class="EngineeringManagementApp.Views.Pages.EchipamentePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      FontFamily="{StaticResource AppFont}"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Echipamente" Style="{StaticResource PageTitleStyle}" />
        <TextBlock Grid.Row="1"
                   Text="Inventar echipamente"
                   Style="{StaticResource PageSubtitleStyle}"
                   Margin="0,6,0,16" />

        <StackPanel Grid.Row="2">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="BtnAdauga" Content="➕ Adaugă" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Adauga_Click" />
                <Button x:Name="BtnEditeaza" Content="✏ Editează" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Editeaza_Click" />
                <Button x:Name="BtnSterge" Content="🗑 Șterge" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Sterge_Click" />
                <Button Content="🔄 Reîncarcă" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Reincarca_Click" />
                <Button x:Name="BtnExport" Content="📤 Export Excel" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Export_Click" />
                <Button x:Name="BtnImport" Content="📥 Import Excel" Style="{StaticResource SecondaryButtonStyle}" Click="Import_Click" />
            </StackPanel>

            <DataGrid x:Name="GridDate"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Background="{DynamicResource SurfaceBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      AlternatingRowBackground="{DynamicResource PrimaryLightBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      MinHeight="300">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdEchipament}" Width="50" />
                    <DataGridTextColumn Header="Tip echipament" Binding="{Binding TipEchipament}" Width="*" />
                    <DataGridTextColumn Header="Model" Binding="{Binding ModelEchipament}" Width="*" />
                    <DataGridTextColumn Header="Nr. serie" Binding="{Binding NrSerie}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>
