<Application x:Class="EngineeringManagementApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup"
             Exit="Application_Exit"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Stiluri comune (butoane, etichete) -->
                <ResourceDictionary Source="Resources/SharedStyles.xaml" />
                <!-- Tema deschisă — implicit la pornire -->
                <ResourceDictionary Source="Resources/ThemeLight.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
