<Window x:Class="EngineeringManagementApp.Views.Dialogs.SolicitareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solicitare"
        Height="700"
        Width="480"
        MinHeight="560"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TitluText" Text="Adaugă solicitare" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,20" />

                <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox x:Name="StatusCombo" Margin="0,0,0,12" Padding="10,8" />

                <TextBlock Text="Inginer *" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox x:Name="InginerCombo" Margin="0,0,0,12" Padding="10,8" SelectionChanged="InginerCombo_SelectionChanged" />

                <TextBlock Text="Client *" Style="{StaticResource FieldLabelStyle}" />
                <TextBox x:Name="ClientBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <TextBlock Text="Adresă" Style="{StaticResource FieldLabelStyle}" />
                <TextBox x:Name="AdresaBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <TextBlock Text="Data" Style="{StaticResource FieldLabelStyle}" />
                <DatePicker x:Name="DataPicker" Margin="0,0,0,12" />

                <TextBlock Text="Echipament *" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox x:Name="EchipamentCombo" Margin="0,0,0,12" Padding="10,8" SelectionChanged="EchipamentCombo_SelectionChanged" />

                <TextBlock Text="Cantitate echipament" Style="{StaticResource FieldLabelStyle}" />
                <TextBox x:Name="CantitateBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" TextChanged="CantitateBox_TextChanged" />

                <TextBlock Text="Sumă achitare (MDL) *" Style="{StaticResource FieldLabelStyle}" />
                <TextBlock Text="Obligatorie la salvare (sau calcul automat: cantitate × 400 MDL)"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,4" />
                <TextBox x:Name="SumaBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <TextBlock x:Name="EroareText"
                           Foreground="{DynamicResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,16,0,0"
                Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anulează" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="Anuleaza_Click" />
                <Button Content="Salvează" Style="{StaticResource PrimaryButtonStyle}" Click="Salveaza_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
