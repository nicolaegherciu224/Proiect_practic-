<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Tema întunecată: albastru închis și gri/negru -->
    <Color x:Key="PrimaryColor">#3D7DD4</Color>
    <Color x:Key="PrimaryDarkColor">#1E3A5F</Color>
    <Color x:Key="PrimaryLightColor">#253550</Color>
    <Color x:Key="AccentColor">#5A9AE8</Color>

    <Color x:Key="BackgroundColor">#0F1419</Color>
    <Color x:Key="SurfaceColor">#1A2332</Color>
    <Color x:Key="SidebarColor">#121A26</Color>
    <Color x:Key="SidebarHoverColor">#1E2D42</Color>
    <Color x:Key="SidebarActiveColor">#2D5A8A</Color>
    <Color x:Key="TopBarColor">#1A2332</Color>
    <Color x:Key="BorderColor">#2E3F55</Color>
    <Color x:Key="TextPrimaryColor">#E8EDF4</Color>
    <Color x:Key="TextSecondaryColor">#9AABBF</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextOnSidebarColor">#C8D8EC</Color>
    <Color x:Key="ErrorColor">#E86B6B</Color>
    <Color x:Key="SuccessColor">#4CB87A</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}" />
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}" />
    <SolidColorBrush x:Key="TopBarBrush" Color="{StaticResource TopBarColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimaryColor}" />
    <SolidColorBrush x:Key="TextOnSidebarBrush" Color="{StaticResource TextOnSidebarColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

</ResourceDictionary>
